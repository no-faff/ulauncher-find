{
  "required_api_version": "^2.0.0",
  "name": "Find",
  "description": "Find files and directories by name using fd (exact matching)",
  "developer_name": "No Faff",
  "icon": "images/icon.png",
  "options": {
    "query_debounce": 0.5
  },
  "preferences": [
    {
      "id": "kw_all",
      "type": "keyword",
      "name": "Find files and directories",
      "default_value": "fd"
    },
    {
      "id": "kw_files",
      "type": "keyword",
      "name": "Find files only",
      "default_value": "ff"
    },
    {
      "id": "kw_dirs",
      "type": "keyword",
      "name": "Find directories only",
      "default_value": "fdir"
    },
    {
      "id": "alt_enter_action",
      "type": "select",
      "name": "Alt+Enter action",
      "description": "What happens when you press Alt+Enter on a result.",
      "default_value": 0,
      "options": [
        {
          "text": "Open containing folder",
          "value": 0
        },
        {
          "text": "Open folder in terminal",
          "value": 1
        },
        {
          "text": "Copy path to clipboard",
          "value": 2
        }
      ]
    },
    {
      "id": "base_dir",
      "type": "input",
      "name": "Base directory",
      "description": "Where to search from. Use / to search everywhere.",
      "default_value": "/"
    },
    {
      "id": "result_limit",
      "type": "input",
      "name": "Result limit",
      "description": "Maximum number of results to show.",
      "default_value": "15"
    },
    {
      "id": "allow_hidden",
      "type": "select",
      "name": "Include hidden files",
      "description": "Search hidden files and directories (names starting with a dot).",
      "default_value": 0,
      "options": [
        {
          "text": "No",
          "value": 0
        },
        {
          "text": "Yes",
          "value": 1
        }
      ]
    },
    {
      "id": "follow_symlinks",
      "type": "select",
      "name": "Follow symbolic links",
      "description": "Follow symlinked directories when searching.",
      "default_value": 0,
      "options": [
        {
          "text": "No",
          "value": 0
        },
        {
          "text": "Yes",
          "value": 1
        }
      ]
    },
    {
      "id": "ignore_file",
      "type": "input",
      "name": "Ignore file",
      "description": "Path to a .gitignore-style file listing paths to skip.",
      "default_value": ""
    },
    {
      "id": "terminal_cmd",
      "type": "input",
      "name": "Terminal command",
      "description": "Terminal emulator for 'Open in terminal'. Leave blank to auto-detect.",
      "default_value": ""
    }
  ]
}
